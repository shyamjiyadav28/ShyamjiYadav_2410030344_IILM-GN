class Solution:
    def countBalanced(self, arr):
        def get_value(s):
            vowels = set('aeiou')
            v = 0
            c = 0
            for ch in s:
                if ch in vowels:
                    v += 1
                else:
                    c += 1
            return v - c
        
        prefix_sum = 0
        freq = {0: 1}  # important
        count = 0
        
        for s in arr:
            prefix_sum += get_value(s)
            
            if prefix_sum in freq:
                count += freq[prefix_sum]
            
            freq[prefix_sum] = freq.get(prefix_sum, 0) + 1
        
        return count
